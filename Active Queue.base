views:
  - type: table
    name: Table
    filters:
      and:
        - type == "nugget"
    order:
      - file.name
      - status
      - format
      - topic
      - date posted
    sort:
      - property: status
        direction: DESC
  - type: cards
    name: Cards
    filters:
      and:
        - type == "nugget"
  - type: table
    name: Kanban
